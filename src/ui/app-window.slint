import { Button, ScrollView, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    no-frame: true;
    background: transparent;
    width: 500px;
    height: 700px;
    in-out property <[string]> results: ["KLIKNIJ I CIĄGNIJ GÓRĘ", "ABY PRZESUNĄĆ"];
    callback quit();
    callback send(string);
    callback move_window(length, length); // Przywracamy, skoro działało!

    // Główny kontener - JAWNE POWIĄZANIE Z OKNEM
    Rectangle {
        width: root.width;
        height: root.height;
        background: #1c1c1c;
        border-radius: 12px;
        border-width: 2px;
        border-color: #00ff00;
        clip: true;
        VerticalLayout {
            // OBSZAR DO PRZESUWANIA (TitleBar zastępczy)
            Rectangle {
                height: 50px;
                background: #333;
                Text {
                    text: "CHWYĆ MNIE (DRAG)";
                    color: white;
                }

                TouchArea {
                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                            root.move_window(0px, 0px); // Sygnał start_drag
                        }
                    }
                }
            }

            VerticalLayout {
                padding: 20px;
                spacing: 15px;
                input := LineEdit {
                    placeholder-text: "Wzór...";
                    height: 35px;
                }

                Button {
                    text: "GENERUJ";
                    height: 40px;
                    clicked => {
                        root.send(input.text);
                    }
                }

                Rectangle {
                    background: #2d2d2d;
                    vertical-stretch: 1;
                    ScrollView {
                        VerticalLayout {
                            padding: 10px;
                            for res in root.results: Text {
                                text: res;
                                color: #00ff00;
                            }
                        }
                    }
                }

                // Przycisk wyjścia
                Button {
                    text: "ZAMKNIJ";
                    clicked => {
                        root.quit();
                    }
                }
            }
        }
    }
}
