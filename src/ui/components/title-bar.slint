import { Palette } from "../theme/globals.slint";
import "../fonts/BlexMonoNerdFont-Bold.ttf";
import "../fonts/RammettoOne-Regular.ttf";
// kody ikon są SPECIFICZNE dla Nerd Fonts i na 100% są w pliku BlexMono
// https://www.nerdfonts.com/cheat-sheet

export component WindowControlBtn inherits Rectangle {
    in property <string> text;
    in property <bool> is-danger: false; // True dla przycisku zamknięcia

    callback clicked();

    // STYL WINDOWSOWY:
    width: 46px;
    height: 100%;
    border-radius: 0px; 

    // Kolor tła:
    background: touch.has-hover ? (root.is-danger ? Palette.accent-danger : Palette.hover-background) : transparent;
    
    // Animacja jest w Windows błyskawiczna lub bardzo szybka
    animate background { duration: 100ms; }
    Text {
        text: root.text;

        // - Jeśli najechano na "Close" (is-danger) -> Zawsze Biały
        // - Jeśli tryb ciemny -> Biały
        // - Jeśli tryb jasny -> Ciemny szary 
        color: (touch.has-hover && root.is-danger) ? white : Palette.text-primary;
        font-family: "BlexMono Nerd Font";
        font-weight: 700;
        font-size: 16px;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component CustomTitleBar inherits Rectangle {
    in property <string> title-text;
    callback close-clicked();
    callback minimize-clicked();
    callback theme-toggle-clicked();
    callback move-window(length, length); 

    // Wysokość standardowa dla Windows to ok. 32-40px
    height: 35px;
    background: Palette.title-bar-background; // Kolor tła paska

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;
        TouchArea {
            horizontal-stretch: 1;

            // Zmienne lokalne (dlatego nie używamy 'root.', tylko nazwy wprost)
            property <length> start-x;
            property <length> start-y;
            property <bool> is-touch-drag: false;
            pointer-event(event) => {
                // 1. START (Naciśnięcie)
                if (event.kind == PointerEventKind.down) {
                    if (event.button == PointerEventButton.left) {
                        // MYSZ -> Wyślij 0,0 (Sygnał dla Native Drag w Rust)
                        root.move-window(0px, 0px);
                        is-touch-drag = false;
                    } else {
                        // DOTYK -> Zapamiętaj gdzie dotknięto
                        // POPRAWKA: Używamy 'self.mouse-x' zamiast 'event.x'
                        start-x = self.mouse-x;
                        start-y = self.mouse-y;
                        is-touch-drag = true;
                    }
                }
                
                // 2. RUCH (Tylko dla dotyku)
                if (event.kind == PointerEventKind.move && is-touch-drag) {
                     // POPRAWKA: Obliczamy różnicę używając 'self.mouse-x'
                     let dx = self.mouse-x - start-x;
                    let dy = self.mouse-y - start-y;
                     
                     // Wyślij deltę do Rusta
                     root.move-window(dx, dy);
                }

                // 3. STOP (Puszczenie)
                if (event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel) {
                    is-touch-drag = false;
                }
            }
            HorizontalLayout {
                padding-left: 10px;
                alignment: start;
                Text {
                    text: root.title-text;
                    vertical-alignment: center;
                    color: Palette.text-secondary;
                    font-family: "Rammetto One";
                    font-weight: 400;
                    font-size: 12px;
                }
            }
        }

        WindowControlBtn {
            // Ikona: Dark/Light Theme
            text: Palette.is-dark ? "\u{f0336}" : "\u{f0335}";
            clicked => {
                root.theme-toggle-clicked();
            }
        }

        WindowControlBtn {
            // Ikona: Window Minimize
            text: "\u{f2d1}";
            clicked => {
                root.minimize-clicked();
            }
        }

        WindowControlBtn {
            // Ikona: Close 
            text: "\u{f00d}";
            is-danger: true;
            clicked => {
                root.close-clicked();
            }
        }
    }
}
