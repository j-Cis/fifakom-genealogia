export global Palette {
    // To jest nasz główny przełącznik trybu. 
    // Inne pliki mogą go zmieniać (Palette.is-dark = !Palette.is-dark)
    in-out property <bool> is-dark: true;

    // --- KOLORY TŁA (BACKGROUNDS) ---
    out property <brush> background: is-dark ? #1e1e1e : #f0f0f0;
    out property <brush> background-light: is-dark ? #2d2d2d : #ffffff; // Np. dla kart lub inputów
    out property <brush> title-bar-background: is-dark ? #2d2d2d : #dddddd;

    // --- KOLORY TEKSTU (FOREGROUNDS) ---
    out property <brush> text-primary: is-dark ? #ffffff : #1e1e1e;
    out property <brush> text-secondary: is-dark ? #aaaaaa : #666666;

    // --- ELEMENTY INTERFEJSU (UI) ---
    out property <brush> border: is-dark ? #444444 : #cccccc;
    out property <brush> hover-background: is-dark ? #ffffff1a : #0000001a;
    
    // --- SPECIALNE ---
    out property <brush> accent-danger: #c42b1c; // Czerwony (Close)
    out property <brush> accent-danger-hover: #e81123;
}
