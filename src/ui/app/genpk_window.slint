import { Palette } from "../theme/globals.slint";
import { WindowShell, CustomBtn } from "../components/window-shell.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

export component GenpkWindow inherits Window {
    no-frame: true;
    background: transparent;
    preferred-width: 600px;
    preferred-height: 300px;
    
    // Właściwości i callbacki - dokładnie te, których używa Twój Rust
    in-out property <[string]> results: [];
    in-out property <string> joined_text: "";
    in-out property <bool> show_as_list: true;
    callback quit();
    callback minimize(); // Dodane dla ramy
    callback window_resize(string);
    callback window_move(length, length);
    callback send(string);
    callback copy_to_clipboard(string);
    WindowShell {
        width: 100%;
        height: 100%;
        window-title: "CPSGen - FORMATOWANIE";
        
        // Podpięcie ramy pod callbacki okna
        close-clicked => {
            root.quit();
        }
        minimize-clicked => {
            root.minimize();
        }
        window-move(dx, dy) => {
            root.window_move(dx, dy);
        }
        window-resize(dir) => {
            root.window_resize(dir);
        }

        // TWOJA ZAWARTOŚĆ (Kopia Twojej logiki)
        VerticalLayout {
            padding: 20px;
            spacing: 15px;
            alignment: start;
            input := LineEdit {
                placeholder-text: "Wzór...";
                height: 35px;
                accepted => {
                    root.send(self.text);
                }
            }

            HorizontalLayout {
                spacing: 10px;
                height: 35px;
                CustomBtn {
                    text: "LISTA";
                    enabled: !root.show_as_list;
                    clicked => {
                        root.show_as_list = true;
                    }
                }

                CustomBtn {
                    text: "TEKST";
                    enabled: root.show_as_list;
                    clicked => {
                        root.show_as_list = false;
                    }
                }
            }

            CustomBtn {
                text: "GENERUJ";
                height: 40px;
                primary: true;
                clicked => {
                    root.send(input.text);
                }
            }

            Rectangle {
                background: Palette.background-light;
                border-radius: 4px;
                vertical-stretch: 1;
                clip: true;
                ScrollView {
                    viewport-width: self.width;
                    if (root.show_as_list): VerticalLayout {
                        padding: 10px;
                        spacing: 5px;
                        for res in root.results: Text {
                            text: res;
                            color: Palette.accent-success;
                        }
                    }
                    if (!root.show_as_list): VerticalLayout {
                        padding: 10px;
                        Text {
                            text: root.joined_text;
                            color: Palette.accent-success;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            CustomBtn {
                text: "KOPIUJ WYNIKI";
                clicked => {
                    root.copy_to_clipboard(root.show_as_list ? "list" : "text");
                }
            }
        }
    }
}
