import { Palette } from "../theme/globals.slint";
import {
    WindowShell,
    WindowCtrl,
    CustomBtn,
} from "../components/window-shell.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

export struct MapPoint {
    x: float, // Zmiana na float! (procent szerokości 0.0-1.0) x: length,
    y: float, // Zmiana na float! (procent wysokości 0.0-1.0) y: length,
    nazwa: string,
}

export component GenetekaCoJestWindow inherits WindowShell {
    preferred-width: 600px;
    preferred-height: 800px;
    window-title: "GENETEKA - CO JEST?";

    
    // Właściwości i callbacki dla Rusta
    callback search(string);
    in property <[MapPoint]> map_points: [];
    in property <length> map_canvas_width: 700px;
    in property <length> map_canvas_height: 600px;
    in-out property <[string]> search_results: [];
    in-out property <float> map_zoom: 1.0;
    VerticalLayout {
        padding: 20px;
        spacing: 15px;
        HorizontalLayout {
            spacing: 10px;
            height: 40px;
            input := LineEdit {
                placeholder-text: "Szukaj parafii...";
                accepted => {
                    root.search(self.text);
                }
            }

            CustomBtn {
                text: "SZUKAJ";
                width: 100px;
                primary: true;
                clicked => {
                    root.search(input.text);
                }
            }
        }

        Rectangle {
            background: Palette.background-light;
            border-radius: 4px;
            vertical-stretch: 1;
            clip: true;

            // --- NASZA MAPA ---
            Rectangle {
                //height: root.map_canvas_height;
                horizontal-stretch: 1;
                background: Palette.background-light;
                border-radius: 4px;
                border-width: 1px;
                border-color: Palette.accent-success;
                clip: true;
                flick := Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: map_layer.width;      //viewport-width: self.width * root.map_zoom;
                    viewport-height: map_layer.height;    //viewport-height: self.height * root.map_zoom;
                    
                    map_layer := Rectangle {
                        // Rozmiar wirtualnego płótna rośnie wraz z zoomem
                        width: flick.width * root.map_zoom;
                        height: flick.height * root.map_zoom;
                        for pt in root.map_points: Rectangle {
                            // parent to teraz jednoznacznie `map_layer`
                            x: pt.x * parent.width - 2px;
                            y: pt.y * parent.height - 2px;
                            width: 4px;
                            height: 4px;
                            background: #ff0055;
                            border-radius: 2px;
                        }
                    }
                }

                HorizontalLayout {
                    x: parent.width - self.width - 10px;
                    y: 10px;
                    spacing: 5px;
                    CustomBtn {
                        text: "－";
                        width: 30px;
                        height: 30px;
                        clicked => {
                            root.map_zoom = Math.max(1.0, root.map_zoom - 0.5);
                        }
                    }

                    CustomBtn {
                        text: "O";
                        width: 30px;
                        height: 30px;
                        clicked => {
                            root.map_zoom = 1.0;
                        }
                    }

                    CustomBtn {
                        text: "＋";
                        width: 30px;
                        height: 30px;
                        clicked => {
                            root.map_zoom += 0.5;
                        }
                    }
                }
                    
                    // Opcjonalnie: podpowiedź po najechaniu myszką
                    // tooltip: pt.nazwa; (Slint wspiera proste tooltipy, ale to na później)
            }
        }

        Rectangle {
            background: Palette.background-light;
            border-radius: 4px;
            vertical-stretch: 1;
            clip: true;
            ScrollView {
                viewport-width: self.width;
                VerticalLayout {
                    padding: 10px;
                    spacing: 5px;
                    for res in root.search_results: Text {
                        text: res;
                        color: Palette.accent-success;
                        font-family: "Fira Code";
                    }
                }
            }
        }
    }
}
