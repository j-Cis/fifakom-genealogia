import { Palette } from "../theme/globals.slint";
import { WindowShell, CustomBtn } from "../components/window-shell.slint";
import { LineEdit } from "std-widgets.slint";

import { MapaKanwa, MapPoint } from "../components/mapa-kanwa.slint";
import { MapaKokpit, MapaCelownik } from "../components/mapa-kokpit.slint";

export { MapPoint } 

export component GenetekaCoJestWindow inherits WindowShell {
    preferred-width: 1600px;
    preferred-height: 1000px;
    window-title: "GENETEKA - CO JEST?";
    callback search(string);
    //in property <[MapPoint]> map_points: [];
    in property <image> map_frame;
    callback camera_changed(float, float, float, float, float, float);
    in-out property <[string]> search_results: [];

    // ==========================================
    // BRAKUJĄCE ZMIENNE I FUNKCJE (PRZYWRÓCONE)
    // ==========================================
    in property <float> geo_min_lon;
    in property <float> geo_max_lon;
    in property <float> geo_min_lat;
    in property <float> geo_max_lat;
    pure function current_lat() -> string {
        let view_center_x = kanwa.width / 2;
        let view_center_y = kanwa.height / 2;
        let target_x = view_center_x - kanwa.map_offset_x;
        let target_y = view_center_y - kanwa.map_offset_y;
        let pivot_x = kanwa.width * kanwa.map_zoom / 2;
        let pivot_y = kanwa.height * kanwa.map_zoom / 2;
        let dx = target_x - pivot_x;
        let dy = target_y - pivot_y;
        
        // Cofamy obrót (stąd minus)
        let cos_a = Math.cos(-kanwa.map_rotation);
        let sin_a = Math.sin(-kanwa.map_rotation);
        let orig_y = pivot_y + dx * sin_a + dy * cos_a;
        let ratio = orig_y / (kanwa.height * kanwa.map_zoom);
        let val = geo_max_lat - (ratio * (geo_max_lat - geo_min_lat));
        // ZMIANA: Obsługa N / S
        let prefix = val >= 0 ? "N:" : "S:";
        let val_abs = Math.abs(val);
        return prefix + " " + Math.round(val_abs * 10000) / 10000 + "°";
    }
    pure function current_lon() -> string {
        let view_center_x = kanwa.width / 2;
        let view_center_y = kanwa.height / 2;
        let target_x = view_center_x - kanwa.map_offset_x;
        let target_y = view_center_y - kanwa.map_offset_y;
        let pivot_x = kanwa.width * kanwa.map_zoom / 2;
        let pivot_y = kanwa.height * kanwa.map_zoom / 2;
        let dx = target_x - pivot_x;
        let dy = target_y - pivot_y;
        let cos_a = Math.cos(-kanwa.map_rotation);
        let sin_a = Math.sin(-kanwa.map_rotation);
        let orig_x = pivot_x + dx * cos_a - dy * sin_a;
        let ratio = orig_x / (kanwa.width * kanwa.map_zoom);
        let val = geo_min_lon + (ratio * (geo_max_lon - geo_min_lon));
        // ZMIANA: Obsługa E / W
        let prefix = val >= 0 ? "E:" : "W:";
        let val_abs = Math.abs(val);
        return prefix + " " + Math.round(val_abs * 10000) / 10000 + "°";
    }
    // ==========================================

    // DODANE: Czyste funkcje do formatowania obrotu i zooma
    pure function current_rot() -> string {
        let deg = Math.mod(kanwa.map_rotation / 1deg, 360);
        let final_deg = deg < 0 ? deg + 360 : deg; // Zawijanie na 360
        return Math.round(final_deg) + "°";
    }
    pure function current_zoom() -> string {
        // Pokazujemy 2 miejsca po przecinku dla ułamkowych powiększeń
        return (Math.round(kanwa.map_zoom * 100) / 100) + "x";
    }
    VerticalLayout {
        padding: 20px;
        spacing: 15px;
        HorizontalLayout {
            spacing: 10px;
            height: 40px;
            input := LineEdit {
                placeholder-text: "Szukaj parafii...";
                accepted => {
                    root.search(self.text);
                }
            }

            CustomBtn {
                text: "SZUKAJ";
                width: 100px;
                primary: true;
                clicked => {
                    root.search(input.text);
                }
            }
        }

        kanwa := MapaKanwa {
            map_frame: root.map_frame;
            camera_changed(w, h, ox, oy, z, rot) => {
                root.camera_changed(w, h, ox, oy, z, rot);
            }

            // 1. CELOWNIK I LICZNIK (Warstwa informacyjna)
            MapaCelownik {
                width: 100%;
                height: 100%;
                n_coord: root.current_lat();
                e_coord: root.current_lon();
                zoom_str: root.current_zoom(); // Pociągnięte z nowej funkcji
                rot_str: root.current_rot();   // Pociągnięte z nowej funkcji
                anchor: "ne"; // Licznik w prawym górnym rogu
            }

            // 2. KOKPIT (Warstwa sterowania)
            MapaKokpit {
                anchor: "sw";
                margin: 10px;
                x: (self.anchor == "nw" || self.anchor == "sw") ? self.margin : parent.width - self.preferred-width - self.margin;
                y: (self.anchor == "nw" || self.anchor == "ne") ? self.margin : parent.height - self.preferred-height - self.margin;
                zoom_in => {
                    // kanwa.zoom_around_center(kanwa.map_zoom + 0.75);
                    kanwa.zoom_around_center(kanwa.map_zoom * 1.15);
                }
                zoom_out => {
                    // kanwa.zoom_around_center(kanwa.map_zoom - 0.75);
                    kanwa.zoom_around_center(kanwa.map_zoom / 1.15);
                }
                rotate_ccw => {
                    kanwa.rotate_view(-5deg);
                }
                rotate_cw => {
                    kanwa.rotate_view(5deg);
                }
                pan(dx, dy) => {
                    kanwa.map_offset_x += dx;
                    kanwa.map_offset_y += dy;
                    kanwa.trigger_render();
                }
                reset => {
                    kanwa.map_zoom = 1.0;
                    kanwa.map_offset_x = 0px;
                    kanwa.map_offset_y = 0px;
                    kanwa.map_rotation = 0deg;
                    kanwa.trigger_render();
                }
            }
        }
    }
}
